{
  "name": "braindrive",
  "version": "26.6.30",
  "description": "BrainDrive core runtime: gateway, engine, auth, memory, and web client",
  "private": true,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BrainDriveAI/braindrive.git",
    "directory": "builds/typescript"
  },
  "homepage": "https://braindrive.ai",
  "bugs": {
    "url": "https://github.com/BrainDriveAI/braindrive/issues"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node scripts/dev-runtime.mjs --web",
    "dev:server": "node scripts/dev-runtime.mjs",
    "dev:gateway": "tsx gateway/server.ts",
    "dev:cli": "tsx client/repl.ts",
    "dev:web": "npm --prefix client_web run dev",
    "memory:init": "tsx scripts/memory-init.ts",
    "identity:check": "node scripts/identity-cleanup-check.mjs",
    "identity:check:desktop-runtime": "node scripts/identity-cleanup-check.mjs --include-generated-runtime",
    "smoke:upload": "tsx scripts/upload-smoke.ts",
    "secrets": "tsx secrets/cli.ts",
    "start": "node dist/main.js",
    "start:server": "node dist/gateway/server.js",
    "start:cli": "node dist/client/repl.js",
    "test": "vitest run",
    "web:install": "npm --prefix client_web ci",
    "web:typecheck": "npm --prefix client_web run typecheck",
    "web:test": "npm --prefix client_web run test",
    "web:build": "npm --prefix client_web run build",
    "desktop:preflight": "npm run build && npm --prefix ../mcp_release run build && npm --prefix client_web run typecheck",
    "desktop:stage-runtime": "node scripts/desktop-stage-runtime.mjs",
    "desktop:stage-runtime:powershell": "powershell -ExecutionPolicy Bypass -File scripts/desktop-stage-runtime.ps1",
    "desktop:dev": "tauri dev",
    "desktop:release-aliases": "node scripts/desktop-release-aliases.mjs",
    "desktop:build": "tauri build && npm run desktop:release-aliases",
    "desktop:build:mac": "tauri build --bundles dmg && npm run desktop:release-aliases",
    "desktop:build:mac:remote": "powershell -ExecutionPolicy Bypass -File scripts/remote-mac-build.ps1",
    "desktop:build:windows": "tauri build --bundles nsis && npm run desktop:release-aliases",
    "desktop:build:linux": "tauri build --bundles deb,appimage",
    "desktop:build:frontend": "npm --prefix client_web run build",
    "desktop:dev:web": "npm --prefix client_web run dev",
    "desktop:test": "npm run test && npm --prefix ../mcp_release run build && npm --prefix client_web run test && cargo test --manifest-path src-tauri/Cargo.toml"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fastify": "^5.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^26.1.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
