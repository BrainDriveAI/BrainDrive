:80 {
  encode zstd gzip

  @api path /api /api/*
  handle @api {
    uri strip_prefix /api
    reverse_proxy app:8787 {
      flush_interval -1
    }
  }

  @health path /health
  handle @health {
    reverse_proxy app:8787
  }

  handle {
    root * /usr/share/caddy
    try_files {path} /index.html
    file_server
  }
}
