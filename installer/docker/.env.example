# Required for production HTTPS
DOMAIN=app.example.com

# Image coordinates
BRAINDRIVE_TAG=latest
BRAINDRIVE_APP_IMAGE=ghcr.io/braindrive-ai/braindrive-app
BRAINDRIVE_EDGE_IMAGE=ghcr.io/braindrive-ai/braindrive-edge

# Optional immutable image references (recommended for production).
# If you set one, set both.
# Example:
# BRAINDRIVE_APP_REF=ghcr.io/braindrive-ai/braindrive-app@sha256:...
# BRAINDRIVE_EDGE_REF=ghcr.io/braindrive-ai/braindrive-edge@sha256:...
BRAINDRIVE_APP_REF=
BRAINDRIVE_EDGE_REF=

# Optional manifest-driven release resolution for upgrades.
# Set BRAINDRIVE_RELEASE_MANIFEST to a local releases.json file.
# If BRAINDRIVE_APP_REF/BRAINDRIVE_EDGE_REF are unset, upgrade scripts can resolve
# digest refs from this manifest using the selected channel/version.
BRAINDRIVE_RELEASE_MANIFEST=
BRAINDRIVE_RELEASE_CHANNEL=stable
BRAINDRIVE_RELEASE_VERSION=
BRAINDRIVE_REQUIRE_MANIFEST_SIGNATURE=true
# Path to detached manifest signature created during release publish.
BRAINDRIVE_RELEASE_MANIFEST_SIG=
# Path to trusted release public key used to verify manifest signatures.
# This is NOT the same as PAA_SECRETS_MASTER_KEY_B64.
BRAINDRIVE_RELEASE_PUBLIC_KEY=

# Required for encrypted secrets at runtime
PAA_SECRETS_MASTER_KEY_B64=
PAA_SECRETS_MASTER_KEY_ID=owner-master-v1

# Optional hardening / behavior
PAA_AUTH_BOOTSTRAP_TOKEN=
PAA_AUTH_ALLOW_FIRST_SIGNUP_ANY_IP=true
TZ=UTC

# Local-mode HTTP bind host (127.0.0.1 = this machine only, 0.0.0.0 = LAN)
BRAINDRIVE_LOCAL_BIND_HOST=127.0.0.1
